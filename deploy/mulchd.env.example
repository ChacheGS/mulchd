MULCHD_HOST=0.0.0.0
MULCHD_PORT=8000
# python -c "import secrets; print(secrets.token_hex(32))"
MULCHD_SECRET_KEY=

# Grants SUPERADMIN to this email on first OAuth login, but only while no
# admin exists yet — becomes permanently inert once any admin grant exists,
# even if this stays set. Leave blank if bootstrapping via the CLI instead
# (see `make bootstrap-admin`).
MULCHD_BOOTSTRAP_ADMIN_EMAIL=

# OAuth — GitHub (optional; omit to disable GitHub login at /connect)
# MULCHD_GITHUB_CLIENT_ID=
# MULCHD_GITHUB_CLIENT_SECRET=

# OAuth — Generic OIDC (optional; works with Google, Entra, Okta, Keycloak, etc.)
# MULCHD_OIDC_DISCOVERY_URL=
# MULCHD_OIDC_CLIENT_ID=
# MULCHD_OIDC_CLIENT_SECRET=
# MULCHD_OIDC_DISPLAY_NAME=Google
