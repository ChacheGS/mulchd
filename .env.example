# Copy to .env and fill in values

# DigitalOcean API token — used by Traefik for Let's Encrypt DNS-01 challenge
DO_AUTH_TOKEN=

# ACME email for Let's Encrypt notifications
ACME_EMAIL=

# Postgres password (username and db name are both "mulchd")
POSTGRES_PASSWORD=

# Admin UI auth — required, no defaults
# Generate secret key: python -c "import secrets; print(secrets.token_hex(32))"
MULCHD_SECRET_KEY=
MULCHD_ADMIN_PASSWORD=
