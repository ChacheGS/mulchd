# Copy to .env and fill in values

# Absolute path to the .mulch/ directory the team shares
MULCHD_DATA_PATH=/data/mulch

# SQLite (default) or Postgres for metadata
MULCHD_DB_URL=sqlite://mulchd.db
# MULCHD_DB_URL=postgres://user:pass@localhost:5432/mulchd

MULCHD_HOST=0.0.0.0
MULCHD_PORT=8000

# Admin UI auth — required, no defaults
# Generate secret key: python -c "import secrets; print(secrets.token_hex(32))"
MULCHD_SECRET_KEY=
MULCHD_ADMIN_PASSWORD=
